{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm --prefix prototype ci",
  "buildCommand": "npm --prefix prototype run build",
  "outputDirectory": "prototype/dist",
  "functions": {
    "api/[...path].ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
