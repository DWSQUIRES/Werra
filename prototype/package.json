{
  "name": "werra-prototype",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "api": "tsx server/index.ts",
    "dev": "vite --host 0.0.0.0",
    "dev:poc": "node scripts/dev-with-api.mjs",
    "preview:poc": "node scripts/preview-poc.mjs",
    "preview:poc:reset": "node scripts/preview-poc.mjs --reset",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test:state": "WERRA_DATA_PATH=.werra-poc/state-test-store.json tsx --test --test-concurrency=1 src/state.test.ts server/users.test.ts server/marketplace.test.ts server/usdw.test.ts",
    "test:e2e": "playwright test --config playwright.config.ts",
    "test": "npm run test:state && npm run test:e2e"
  },
  "dependencies": {
    "@ckb-ccc/core": "^1.16.1",
    "@neondatabase/serverless": "^1.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "express": "^5.2.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2"
  }
}
